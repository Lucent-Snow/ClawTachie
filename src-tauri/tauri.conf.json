{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawTachie",
  "version": "0.2.4",
  "identifier": "com.lucentsnow.clawtachie",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run ui:dev",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ClawTachie",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": true
      },
      {
        "label": "pet",
        "title": "ClawTachie Pet",
        "width": 320,
        "height": 520,
        "minWidth": 280,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.clawtachie/characters/**/*",
          "$HOME/.clawtachie/audio/**/*",
          "$DOCUMENT/ZcChat/characters/**/*",
          "$RESOURCE/**/*"
        ]
      },
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:* http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "shortDescription": "ClawTachie desktop companion",
    "longDescription": "A Tauri-based desktop chat companion with optional pet window, session management, and in-app updates.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "startMenuFolder": "ClawTachie"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFODIzMjA4NDUyMzI5NzQKUldSMEtTTkZDREtDem9ZN2RqWEk3VGMwZGIrSjEzc3RMNmdEV3A2NFJMc0g2N3VnWlRmek9LOEMK",
      "endpoints": [
        "https://github.com/Lucent-Snow/ClawTachie/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
